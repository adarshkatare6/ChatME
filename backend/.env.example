# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_MIN=1440

# --- Database (Supabase / Postgres) ---
# Supabase Postgres pooler connection string:
DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- LLM provider & OpenAI Files API ---
# OpenRouter: https://openrouter.ai/api/v1 (model e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet)
# OpenAI:     https://api.openai.com/v1     (model e.g. gpt-4o-mini)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini

# OpenAI API Key (used for OpenAI Files API upload/download/delete)
OPENAI_API_KEY=

# --- CORS (Vercel Frontend URL in Production) ---
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
